    Image:         docker.io/amaddipoti439/modelexpress:vllm-rl-d168542
    Image ID:      docker.io/amaddipoti439/modelexpress@sha256:10530fa7a16a3d3dc2597d15debfaa7c163acfb8c0b2885933c96a818ecec678
    Port:          <none>
    Host Port:     <none>
    Command:
      /bin/bash
      -lc
    Args:
      set -uo pipefail
      mkdir -p /workspace/artifacts
      echo "LEVEL5_POD_START $(date -u +%Y-%m-%dT%H:%M:%SZ)"
      echo "COMMIT $(git -C /workspace/mx rev-parse HEAD)"
      nvidia-smi | tee /workspace/artifacts/nscale-level5-baseline-nvidia-smi-20260605.log
      python3 -m pip install -q '.[dev]' 2>&1 | tee /workspace/artifacts/nscale-level5-baseline-pip-20260605.log
      export PYTHONPATH=/workspace/mx/modelexpress_client/python:${PYTHONPATH:-}
      export NCCL_DEBUG=INFO
      export NCCL_IB_DISABLE=1
      export TORCH_NCCL_ASYNC_ERROR_HANDLING=1
      python3 -m torch.distributed.run --standalone --nnodes=1 --nproc_per_node=4 -m modelexpress.refit_level5 baseline \
        --strategy nccl-reshard-fixed-membership \
        --artifact /workspace/artifacts/nscale-level5-nccl-reshard-baseline-20260605.json \
        2>&1 | tee /workspace/artifacts/nscale-level5-nccl-reshard-baseline-20260605.log
      NCCL_RC=${PIPESTATUS[0]}
      python3 -m torch.distributed.run --standalone --nnodes=1 --nproc_per_node=4 -m modelexpress.refit_level5 baseline \
        --strategy checkpoint-engine-full-gather-apply \
        --artifact /workspace/artifacts/nscale-level5-checkpoint-engine-baseline-20260605.json \
        2>&1 | tee /workspace/artifacts/nscale-level5-checkpoint-engine-baseline-20260605.log
      CE_RC=${PIPESTATUS[0]}
      if [ "$NCCL_RC" -eq 0 ] && [ "$CE_RC" -eq 0 ]; then
        python3 -m modelexpress.refit_level5 table \
          --mx-artifact /workspace/mx/artifacts/resharding/nscale-nixl-distributed-refit.json \
          --nccl-artifact /workspace/artifacts/nscale-level5-nccl-reshard-baseline-20260605.json \
          --checkpoint-artifact /workspace/artifacts/nscale-level5-checkpoint-engine-baseline-20260605.json \
          --claim-scope synthetic-same-node-smoke \
          --artifact /workspace/artifacts/nscale-level5-same-node-synthetic-table-20260605.json \
          2>&1 | tee /workspace/artifacts/nscale-level5-same-node-synthetic-table-20260605.log
        TABLE_RC=${PIPESTATUS[0]}
      else
        TABLE_RC=99
      fi
      python3 - <<PY
      import json, pathlib, time
      summary = {
          "schema_version": 1,
          "local_session_date": "2026-06-05",
          "mode": "level5-baseline-pod-summary",
          "pod": "mx-level5-baseline-20260605-1228",
          "commit": "24f0b0e867f67f0b9a77b880f52eac6de188ba24",
          "requested_gpus": 4,
          "nccl_return_code": int("$NCCL_RC"),
          "checkpoint_engine_return_code": int("$CE_RC"),
          "table_return_code": int("$TABLE_RC"),
          "artifacts": sorted(p.name for p in pathlib.Path('/workspace/artifacts').glob('nscale-level5-*20260605*')),
      }
      pathlib.Path('/workspace/artifacts/nscale-level5-baseline-summary-20260605.json').write_text(json.dumps(summary, indent=2, sort_keys=True) + '\n')
      print('LEVEL5_BASELINE_SUMMARY', json.dumps(summary, sort_keys=True))
      PY
      echo "LEVEL5_POD_DONE $(date -u +%Y-%m-%dT%H:%M:%SZ) rc_nccl=${NCCL_RC} rc_ce=${CE_RC} rc_table=${TABLE_RC}"
      sleep 1800
      exit 0


          export MX_REFIT_ALLOW_GPU_REUSE=1
          export MX_REFIT_DIST_TIMEOUT_MINUTES=10
          export NIXL_LOG_LEVEL=INFO
          export UCX_LOG_LEVEL=warn
          export UCX_TLS=rc_x,rc,dc_x,dc,cuda_copy,cuda_ipc,tcp,self,sm

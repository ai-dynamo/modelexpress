            --artifact-path "$RUN_ART" \
            --gpu-memory-utilization 0.1 \
            --max-model-len 64 \
            --distributed-executor-backend uni
          RUN_RC=$?
          echo "[mx-vllm-trainer-step] run_rc=$RUN_RC"

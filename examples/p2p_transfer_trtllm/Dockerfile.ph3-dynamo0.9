# Phase 3: Dynamo 0.9.0 (TRT-LLM 1.3.0rc1) with live GPU-to-GPU P2P weight transfer
# Based on Dynamo runtime which has working DSV3.2 + FlashMLA support
#
# Build from modelexpress repo root:
#   docker build -t modelexpress-trtllm-client:ph3-dynamo0.9 \
#       -f examples/p2p_transfer_trtllm/Dockerfile.ph3-dynamo0.9 .

FROM nvcr.io/nvidia/ai-dynamo/tensorrtllm-runtime:0.9.0

USER root

# gRPC is needed for ModelExpress client
RUN /opt/dynamo/venv/bin/pip install --no-cache-dir grpcio-tools

# Copy and install ModelExpress client
COPY modelexpress_common/proto /opt/modelexpress/proto
COPY modelexpress_client/python/modelexpress /opt/modelexpress/client/modelexpress
COPY modelexpress_client/python/pyproject.toml /opt/modelexpress/client/

WORKDIR /opt/modelexpress/client
RUN /opt/dynamo/venv/bin/python3 -m grpc_tools.protoc \
        -I/opt/modelexpress/proto \
        --python_out=/opt/modelexpress/client/modelexpress \
        --grpc_python_out=/opt/modelexpress/client/modelexpress \
        /opt/modelexpress/proto/p2p.proto && \
    sed -i 's/^import p2p_pb2/from . import p2p_pb2/' \
        /opt/modelexpress/client/modelexpress/p2p_pb2_grpc.py && \
    /opt/dynamo/venv/bin/pip install --no-deps .

# Apply TRT-LLM patches for LoadFormat.PRESHARDED support (v1.3.0rc1 / Dynamo 0.9.0)
COPY trtllm_patches/v1.3.0rc1/llm_args.py /opt/dynamo/venv/lib/python3.12/site-packages/tensorrt_llm/llmapi/llm_args.py
COPY trtllm_patches/v1.3.0rc1/model_loader.py /opt/dynamo/venv/lib/python3.12/site-packages/tensorrt_llm/_torch/pyexecutor/model_loader.py
COPY trtllm_patches/v1.3.0rc1/linear.py /opt/dynamo/venv/lib/python3.12/site-packages/tensorrt_llm/_torch/modules/linear.py

# Verify
WORKDIR /workspace
RUN /opt/dynamo/venv/bin/python3 -c "from modelexpress.client import MxClient; print('MxClient OK')" && \
    grep -q "PRESHARDED" /opt/dynamo/venv/lib/python3.12/site-packages/tensorrt_llm/llmapi/llm_args.py && \
    echo "PRESHARDED patch applied to TRT-LLM (Dynamo 0.9.0)"

FROM rust:1.90 AS builder

WORKDIR /app

# Install build dependencies
RUN apt-get update && \
    apt-get install -y protobuf-compiler && \
    rm -rf /var/lib/apt/lists/*

# Copy the entire source code
COPY . .

# Build all available binaries
RUN cargo build --release --bin modelexpress-server && \
    cargo build --release --bin modelexpress-cli && \
    cargo build --release --bin test_client && \
    cargo build --release --bin fallback_test

# Generate the Rust third-party license attributions from the resolved
# runtime dependency graph (about.toml ignores build/dev-only crates).
FROM builder AS attributions

RUN apt-get update && \
    apt-get install -y --no-install-recommends python3 && \
    rm -rf /var/lib/apt/lists/*
RUN cargo install cargo-about --version 0.8.4 --locked
RUN cargo about generate --format json -o /tmp/licenses.json && \
    python3 scripts/generate_attributions.py /tmp/licenses.json \
        --md-output ATTRIBUTIONS_Rust.md --csv-output rust_deps.csv

# Snapshot the base image's packages so the dpkg-deps stage can report only
# what this image adds on top of the base.
FROM nvcr.io/nvidia/base/ubuntu:noble-20250619 AS base-snapshot

RUN dpkg-query -W -f '${Package}\n' | sort > /tmp/base_packages.txt

# Shared runtime contents. Kept as a base so the dpkg-deps target inspects the
# exact same package set the shipped image carries, with no drift.
FROM nvcr.io/nvidia/base/ubuntu:noble-20250619 AS runtime-base

WORKDIR /app

# Install runtime dependencies
RUN apt-get update && \
    apt-get install -y --no-install-recommends ca-certificates libssl-dev gpgv && \
    rm -rf /var/lib/apt/lists/*

# Copy all built binaries
COPY --from=builder /app/target/release/modelexpress-server .
COPY --from=builder /app/target/release/modelexpress-cli .
COPY --from=builder /app/target/release/test_client .
COPY --from=builder /app/target/release/fallback_test .

# Copy the Rust attribution file (committed; regenerated by the `attributions`
# target and kept current via the compliance CI drift check).
COPY ATTRIBUTIONS_Rust.md .

# Extract the dpkg packages this image adds over the base image, for OSRB.
# Separate target so the python3 tooling never lands in the shipped `runtime`.
FROM runtime-base AS dpkg-deps

# Capture the shipped package set before adding extraction tooling, so python3
# and its dependencies are not miscounted as runtime dependencies.
RUN dpkg-query -W -f '${Package}\t${Version}\n' | sort > /tmp/runtime_packages.tsv
RUN apt-get update && \
    apt-get install -y --no-install-recommends python3 && \
    rm -rf /var/lib/apt/lists/*
COPY --from=attributions /app/rust_deps.csv .
COPY scripts/calculate_dpkg_deps.py /tmp/
COPY --from=base-snapshot /tmp/base_packages.txt /tmp/base_packages.txt
RUN python3 /tmp/calculate_dpkg_deps.py \
        --baseline /tmp/base_packages.txt \
        --installed /tmp/runtime_packages.tsv \
        /app/dpkg_deps.csv

# Shipped runtime image. Last stage, so a bare `docker build` targets it.
FROM runtime-base AS runtime

# Expose the default port
EXPOSE 8001

# Set default environment variables (can be overridden)
ENV MODEL_EXPRESS_SERVER_PORT=8001
ENV MODEL_EXPRESS_LOG_LEVEL=info
ENV MODEL_EXPRESS_CACHE_DIRECTORY=/app/cache
ENV HF_HUB_CACHE=/app/cache
# Distributed backend is required; operators must set MX_METADATA_BACKEND (drives both
# the P2P and registry backends) plus the relevant connection env vars (REDIS_URL for
# Redis, or POD_NAMESPACE for the Kubernetes backend).

# Run the server by default
CMD ["./modelexpress-server"]
